# ── Secrets (NEVER commit these) ──────────────────────────────────────────────
.env
.env.*
!.env.example

# ── Node modules ──────────────────────────────────────────────────────────────
node_modules/
**/node_modules/

# ── Build outputs ─────────────────────────────────────────────────────────────
dist/
dist-ssr/
build/

# ── Uploaded files (user PDFs) ────────────────────────────────────────────────
backend/uploads/*
!backend/uploads/.gitkeep

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# ── Editor ────────────────────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Vite cache ────────────────────────────────────────────────────────────────
.vite/
*.local
